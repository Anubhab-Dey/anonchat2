# Local defaults are intentionally safe and boring.
DEV_MODE=true
HTTP_ADDR=:8080
PUBLIC_BASE_URL=http://127.0.0.1:8080
ALLOWED_ORIGINS=http://127.0.0.1:8080,http://localhost:8080,http://127.0.0.1:5173,http://localhost:5173
DATABASE_PATH=anonchat.sqlite3
SESSION_COOKIE_NAME=anonchat2_session
SESSION_SECRET=replace-with-at-least-32-random-bytes-in-production
LOG_LEVEL=debug

# Optional first-party ICE servers. Leave empty to avoid third-party ICE by default.
STUN_URLS=
TURN_URLS=
TURN_USERNAME=
TURN_CREDENTIAL=

# Optional built frontend directory. The default is frontend/build from repo root.
STATIC_DIR=frontend/build
